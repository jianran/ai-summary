# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GitHub (auto-detected from gh CLI ~/.config/gh/hosts.yml)
# Uncomment to override with a specific token:
# GITHUB_TOKEN=ghp_your-github-token

# Twitter/X API credentials (OAuth 1.0a + OAuth 2.0 for search)
# Get these from: https://developer.x.com/en/portal/projects
TWITTER_CONSUMER_KEY=your-consumer-key
TWITTER_CONSUMER_SECRET=your-consumer-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret
# OAuth 2.0 Client ID & Secret (auto-generates Bearer Token for search)
TWITTER_CLIENT_ID=your-client-id
TWITTER_CLIENT_SECRET=your-client-secret
# Or set Bearer Token directly (overrides client credentials):
TWITTER_BEARER_TOKEN=your-bearer-token

# Application
DAILY_POST_ENABLED=false
DAILY_POST_CRON=0 0 9 * * *
